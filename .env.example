# ============================================================
# Hotel Voice Agent — Environment Configuration
# ============================================================

# -------------------------------------------------------
# PostgreSQL
# -------------------------------------------------------
POSTGRES_USER=hotel_user
POSTGRES_PASSWORD=hotel_pass

# -------------------------------------------------------
# Booking API
# -------------------------------------------------------
BOOKING_API_KEY=demo-secret-key-2024
# Set this after cloudflared starts — read from: docker logs cloudflared_api
BOOKING_API_PUBLIC_URL=https://YOUR-API-TUNNEL.trycloudflare.com

# -------------------------------------------------------
# n8n
# -------------------------------------------------------
N8N_ENCRYPTION_KEY=change-me-32-chars-minimum-here!!
# Set this after cloudflared starts — read from: docker logs cloudflared_n8n
N8N_WEBHOOK_URL=https://YOUR-N8N-TUNNEL.trycloudflare.com

# -------------------------------------------------------
# AI API Key (for the voice agent intelligence)
# -------------------------------------------------------
ANTHROPIC_API_KEY=your-api-key-here

# -------------------------------------------------------
# ElevenLabs TTS
# get key: https://elevenlabs.io → Profile → API Key
# get voice IDs: https://elevenlabs.io/voice-library
# -------------------------------------------------------
ELEVENLABS_API_KEY=your-elevenlabs-api-key
# Rachel (calm, professional) — good default for hotel
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# -------------------------------------------------------
# Twilio (for reference — configured in Twilio console)
# -------------------------------------------------------
# TWILIO_ACCOUNT_SID=AC...
# TWILIO_AUTH_TOKEN=...
# TWILIO_PHONE_NUMBER=+1...
